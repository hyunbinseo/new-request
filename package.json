{
	"name": "new-request",
	"version": "0.0.40",
	"description": "Type-check and autocomplete for 3rd party REST API requests",
	"homepage": "https://github.com/hyunbinseo/new-request#readme",
	"bugs": {
		"url": "https://github.com/hyunbinseo/new-request/issues"
	},
	"license": "MIT",
	"author": "Hyunbin Seo",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hyunbinseo/new-request.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"imports": {
		"#lib/*": "./src/lib/*"
	},
	"exports": {
		"./email/postmark/POST": "./dist/email/postmark/POST/index.js",
		"./email/send-grid/v3/POST": "./dist/email/send-grid/v3/POST/index.js",
		"./message/bizgo/v1/send/omni/POST": "./dist/message/bizgo/v1/send/omni/POST/index.js",
		"./message/dooray/POST": "./dist/message/dooray/POST/index.js",
		"./message/pushover/1/POST": "./dist/message/pushover/1/POST/index.js",
		"./sms/nhn/v3.0/POST": "./dist/sms/nhn/v3.0/POST/index.js",
		"./sms/twilio/2010-04-01/POST": "./dist/sms/twilio/2010-04-01/POST/index.js",
		"./tts/naver/v1/POST": "./dist/tts/naver/v1/POST/index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"prepack": "tsdown",
		"version": "tsdown && git add package.json",
		"postversion": "git push && git push --tags && node cli/postversion.ts",
		"check": "tsc --noEmit",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@types/node": "^24.12.3",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.63.0",
		"publint": "^0.3.19",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"valibot": "^1.4.0"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912"
}
