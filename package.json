		"./tts/naver/v1": "./dist/tts/naver/v1/index.js",
		"./webhook/dooray": "./dist/webhook/dooray/index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"prepack": "tsdown",
		"version": "tsdown && git add package.json",
		"postversion": "git push && git push --tags && node cli/postversion.ts",
		"check": "tsc --noEmit",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"test": "node --env-file=.env --test"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
